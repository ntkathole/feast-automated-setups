{
  "id": null,
  "uid": "feast-metrics",
  "title": "Feast Feature Server Metrics",
  "tags": ["feast", "feature-store", "prometheus"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "editable": true,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage per Worker",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_feature_server_cpu_usage",
          "legendFormat": "pid={{pid}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage per Worker",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_feature_server_memory_usage",
          "legendFormat": "pid={{pid}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Request Rate (per second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_request_total[1m])",
          "legendFormat": "{{endpoint}} [{{status}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "title": "Total Requests by Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_feature_server_request_total",
          "legendFormat": "{{endpoint}} [{{status}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feast_feature_server_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feast_feature_server_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(feast_feature_server_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 6,
      "title": "Latency by Feature Count (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feast_feature_server_request_latency_seconds_bucket[1m])) by (le, feature_count))",
          "legendFormat": "p95 (features={{feature_count}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 7,
      "title": "Online Feature Requests (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_online_features_request_total[1m])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20, "lineWidth": 2 } }
      }
    },
    {
      "id": 8,
      "title": "Online Store Read Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feast_feature_server_online_store_read_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feast_feature_server_online_store_read_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(feast_feature_server_online_store_read_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 9,
      "title": "ODFV Read Transform Latency by ODFV (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feast_feature_server_transformation_duration_seconds_bucket[1m])) by (le, odfv_name))",
          "legendFormat": "p95 {{odfv_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feast_feature_server_transformation_duration_seconds_bucket[1m])) by (le, odfv_name))",
          "legendFormat": "p50 {{odfv_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 10,
      "title": "ODFV Read Transform Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_transformation_duration_seconds_count[1m])",
          "legendFormat": "{{odfv_name}} ({{mode}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 } }
      }
    },
    {
      "id": 11,
      "title": "ODFV Write Transform Latency by ODFV (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feast_feature_server_write_transformation_duration_seconds_bucket[1m])) by (le, odfv_name))",
          "legendFormat": "p95 {{odfv_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feast_feature_server_write_transformation_duration_seconds_bucket[1m])) by (le, odfv_name))",
          "legendFormat": "p50 {{odfv_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 19,
      "title": "Pandas vs Python ODFV Read Latency (p95)",
      "description": "Side-by-side comparison of p95 read-path ODFV transform latency by transformation mode (pandas vs python).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feast_feature_server_transformation_duration_seconds_bucket{mode=\"pandas\"}[1m])) by (le))",
          "legendFormat": "pandas p95",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feast_feature_server_transformation_duration_seconds_bucket{mode=\"python\"}[1m])) by (le))",
          "legendFormat": "python p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feast_feature_server_transformation_duration_seconds_bucket{mode=\"pandas\"}[1m])) by (le))",
          "legendFormat": "pandas p50",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feast_feature_server_transformation_duration_seconds_bucket{mode=\"python\"}[1m])) by (le))",
          "legendFormat": "python p50",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 20,
      "title": "Pandas vs Python ODFV Transform Rate",
      "description": "Transform invocation rate broken down by mode (pandas vs python) and ODFV name.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(feast_feature_server_transformation_duration_seconds_count{mode=\"pandas\"}[1m]))",
          "legendFormat": "pandas transforms/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(feast_feature_server_transformation_duration_seconds_count{mode=\"python\"}[1m]))",
          "legendFormat": "python transforms/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 } }
      }
    },
    {
      "id": 12,
      "title": "Avg Entities per Request",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_online_features_entity_count_sum / feast_online_features_entity_count_count",
          "legendFormat": "avg entities",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Feature Freshness (staleness)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_feature_freshness_seconds",
          "legendFormat": "{{feature_view}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 14,
      "title": "Materialization Runs",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_materialization_result_total",
          "legendFormat": "{{feature_view}} [{{status}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 15,
      "title": "Materialization Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_materialization_duration_seconds_sum",
          "legendFormat": "{{feature_view}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 15, "lineWidth": 2 } }
      }
    },
    {
      "id": 16,
      "title": "Push Requests by Source & Mode",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 72 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "feast_push_request_total",
          "legendFormat": "{{push_source}} [{{mode}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 17,
      "title": "Push Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 72 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_push_request_total[1m])",
          "legendFormat": "{{push_source}} [{{mode}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } }
      }
    },
    {
      "id": 22,
      "title": "Write Transform Rate",
      "description": "Rate of write-path ODFV transform invocations (triggered by write_to_online_store).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 80 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_write_transformation_duration_seconds_count[1m])",
          "legendFormat": "{{odfv_name}} ({{mode}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 15, "lineWidth": 2 } }
      }
    },
    {
      "id": 21,
      "title": "Avg Write Transform Duration by ODFV",
      "description": "Average write-path transform duration per invocation, per ODFV.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 80 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_write_transformation_duration_seconds_sum[1m]) / rate(feast_feature_server_write_transformation_duration_seconds_count[1m])",
          "legendFormat": "avg {{odfv_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    },
    {
      "id": 23,
      "title": "Latency Breakdown: Store Read vs Transform vs Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 88 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_request_latency_seconds_sum[1m]) / rate(feast_feature_server_request_latency_seconds_count[1m])",
          "legendFormat": "avg total request",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_online_store_read_duration_seconds_sum[1m]) / rate(feast_feature_server_online_store_read_duration_seconds_count[1m])",
          "legendFormat": "avg store read",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_transformation_duration_seconds_sum[1m]) / rate(feast_feature_server_transformation_duration_seconds_count[1m])",
          "legendFormat": "avg read transform",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(feast_feature_server_write_transformation_duration_seconds_sum[1m]) / rate(feast_feature_server_write_transformation_duration_seconds_count[1m])",
          "legendFormat": "avg write transform",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2 } }
      }
    }
  ]
}
